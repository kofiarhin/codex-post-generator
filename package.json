{
  "name": "post-generator",
  "version": "1.0.0",
  "description": "Codex-powered social content workflow — trending software topics to LinkedIn and X posts with Nano Banana-ready visual prompts.",
  "private": true,
  "scripts": {
    "audit:workflow": "node .agents/skills/linkedin-post-orchestrator/scripts/audit_workflow.js",
    "check:duplicates": "node .agents/skills/linkedin-post-orchestrator/scripts/check_duplicates.js",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.mjs",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "db:sync-posts": "node server/scripts/sync-posts.js",
    "finalize:post": "node .agents/skills/linkedin-post-orchestrator/scripts/finalize_post_package.js",
    "save:post": "node .agents/skills/linkedin-post-orchestrator/scripts/save_post.js",
    "save:asset": "node .agents/skills/linkedin-post-assets/scripts/save_asset.js",
    "generate:thumbnail": "node .agents/skills/linkedin-post-assets/scripts/generate_thumbnail.js",
    "test": "npm run test:assets && npm run test:server",
    "test:assets": "node --test .agents/skills/linkedin-post-assets/tests",
    "test:server": "jest server/tests --runInBand",
    "ralph:record-stage": "node .agents/skills/linkedin-post-orchestrator/scripts/record_ralph_stage.js",
    "validate:ralph": "node .agents/skills/linkedin-post-orchestrator/scripts/validate_ralph_article.js",
    "generate:post": "node .agents/skills/linkedin-post-orchestrator/scripts/generate_post.js",
    "generate-post": "npm run generate:post --",
    "post:generate": "npm run generate:post --"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "^4.22.2",
    "mongoose": "^8.24.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.2",
    "jest": "29.7.0",
    "postcss": "^8.5.14",
    "supertest": "^7.2.2",
    "tailwindcss": "3.4.17",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  }
}
